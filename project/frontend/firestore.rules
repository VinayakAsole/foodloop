rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSeller() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller';
    }

    // ── Users ──
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Favorites subcollection
      match /favorites/{favoriteId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Sellers ──
    match /sellers/{sellerId} {
      allow read: if isAuth();
      allow create: if isOwner(sellerId);
      allow update: if isOwner(sellerId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Food Listings ──
    match /foods/{foodId} {
      allow read: if true;                                           // Public browsing
      allow create: if isAuth();                                     // Any logged-in user can list food
      allow update: if isAuth();                                     // Seller or auto-archive on read
      allow delete: if isAdmin();
    }

    // ── Orders ──
    match /orders/{orderId} {
      allow read: if isAuth();                                       // Buyer/seller/admin can read
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Reviews ──
    match /reviews/{reviewId} {
      allow read: if true;                                           // Public reviews
      allow create: if isAuth();
      allow update: if isAuth();                                     // Seller can reply
      allow delete: if isAdmin();
    }

    // ── Announcements ──
    match /announcements/{announcementId} {
      allow read: if true;                                           // Public announcements
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() || isAdmin();
    }

    // ── Coupons (admin-managed) ──
    match /coupons/{couponId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // ── Audit Logs (admin-only) ──
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth();                                     // Functions may log on behalf of admin
      allow update, delete: if false;                                // Immutable logs
    }

    // ── Disputes ──
    match /disputes/{disputeId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Platform Notifications ──
    match /platform_notifications/{notifId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ── Scheduled Listings ──
    match /scheduled_listings/{listingId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Meal Combos ──
    match /combos/{comboId} {
      allow read: if true;                                           // Public browsing
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() || isAdmin();
    }
  }
}
